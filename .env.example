# ─── Required ─────────────────────────────────────────────────────────────────

# Telegram bot token from @BotFather
TELEGRAM_TOKEN=your_telegram_bot_token_here

# Clash of Clans API token from https://developer.clashofclans.com/
# Tokens are tied to specific server IPs — make sure the IP matches the host running the bot
COC_API_TOKEN=your_coc_api_token_here

# ─── Optional (defaults shown) ────────────────────────────────────────────────

# How often the background job polls all clans (seconds)
# COC_POLL_INTERVAL=10

# How often to check for season rollover (seconds)
# COC_SEASON_CHECK_INTERVAL=600

# How often to refresh clan names (seconds)
# COC_CLAN_NAME_REFRESH=3600

# HTTP client timeout (seconds)
# COC_HTTP_TIMEOUT=10

# Days to keep last-season snapshot before auto-deletion
# COC_LAST_SEASON_RETENTION_DAYS=14

# Override storage paths (defaults are <repo>/donation_storage.json + last_season_storage.json)
# COC_STORAGE_FILE=/path/to/donation_storage.json
# COC_LAST_SEASON_FILE=/path/to/last_season_storage.json

# Logging verbosity (DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL=INFO
